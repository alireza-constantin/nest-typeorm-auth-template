DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=better_commerce
DB_SSL_MODE=disable
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000

NODE_ENV=development
PORT=3000
TRUST_PROXY_HOPS=0
TRUSTED_ORIGINS=http://localhost:3000
PUBLIC_REGISTRATION=true
REQUIRE_EMAIL_VERIFICATION=false

# Used only to HMAC identifiers in distributed rate-limit keys. This is not a
# session secret and should be managed/rotated separately in production.
LOGIN_THROTTLE_HMAC_SECRET=development-rate-limit-hmac-secret-change-me
LOGIN_THROTTLE_ACCOUNT_LIMIT=5
LOGIN_THROTTLE_ACCOUNT_WINDOW_SECONDS=900
LOGIN_THROTTLE_IP_LIMIT=20
LOGIN_THROTTLE_IP_WINDOW_SECONDS=60

# Redis is authoritative for sessions. Do not silently fall back to memory.
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
REDIS_CONNECT_TIMEOUT_MS=5000

# Comma-separated secrets support rotation: put the newest secret first and
# retain the previous one until every session signed by it has expired.
# Replace this development-only value with secret-manager values in production.
SESSION_SECRETS=development-only-change-me-0123456789abcdef
SESSION_KEY_PREFIX=bc:sess:
SESSION_COOKIE_NAME=bc.sid
SESSION_IDLE_SECONDS=604800
SESSION_ABSOLUTE_SECONDS=2592000
