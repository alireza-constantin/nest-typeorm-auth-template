# Local-development example only. Copy this file to the ignored root `.env`.
# The application resolves that root file even though the API lives in
# `apps/api`. Never use these credentials or secrets in production.

# These values match the PostgreSQL service in the root docker-compose.yml.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=better_commerce
DB_SSL_MODE=disable
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000

# Runtime and browser origin. TRUSTED_ORIGINS is a comma-separated exact-origin
# allowlist; production origins must use HTTPS.
NODE_ENV=development
PORT=3000
TRUST_PROXY_HOPS=0
TRUSTED_ORIGINS=http://localhost:3000
PUBLIC_REGISTRATION=true
REQUIRE_EMAIL_VERIFICATION=false

# Used only to HMAC identifiers in distributed abuse-limit keys. It is not a
# session signing secret and must be generated and rotated separately in
# production. Redis key prefixes used by abuse protection must retain a cluster
# hash tag such as {auth}.
LOGIN_THROTTLE_HMAC_SECRET=development-rate-limit-hmac-secret-change-me
ABUSE_PROTECTION_KEY_PREFIX=bc:abuse:{auth}:
LOGIN_THROTTLE_IDENTIFIER_LIMIT=5
LOGIN_THROTTLE_IDENTIFIER_WINDOW_SECONDS=900
LOGIN_THROTTLE_IP_LIMIT=20
LOGIN_THROTTLE_IP_WINDOW_SECONDS=60

# Redis is authoritative for sessions. Do not silently fall back to memory.
REDIS_URL=redis://localhost:6379
# REDIS_PORT controls only the host port published by Docker Compose.
REDIS_PORT=6379
REDIS_CONNECT_TIMEOUT_MS=5000

# Comma-separated secrets support rotation: put the newest secret first and
# retain the previous one until every session signed by it has expired.
# Replace this development-only value with secret-manager values in production.
SESSION_SECRETS=development-only-change-me-0123456789abcdef
SESSION_KEY_PREFIX=bc:sess:
# SESSION_COOKIE_NAME is a development/test override. Production always uses
# the secure __Host-bc.sid cookie name.
SESSION_COOKIE_NAME=bc.sid
SESSION_IDLE_SECONDS=604800
SESSION_ABSOLUTE_SECONDS=2592000
