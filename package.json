{
  "name": "better-commerce",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.17.0",
    "pnpm": "11.9.0"
  },
  "scripts": {
    "build": "turbo run build",
    "format": "pnpm --filter @better-commerce/api format",
    "start": "pnpm --filter @better-commerce/api start",
    "start:dev": "pnpm --filter @better-commerce/api start:dev",
    "start:debug": "pnpm --filter @better-commerce/api start:debug",
    "start:prod": "pnpm --filter @better-commerce/api start:prod",
    "lint": "turbo run lint",
    "lint:fix": "pnpm --filter @better-commerce/api lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "pnpm --filter @better-commerce/api test:watch",
    "test:cov": "pnpm --filter @better-commerce/api test:cov",
    "test:debug": "pnpm --filter @better-commerce/api test:debug",
    "test:e2e": "turbo run test:e2e",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down --volumes --remove-orphans && docker compose up -d",
    "db:logs": "docker compose logs -f postgres",
    "staff:bootstrap-owner": "pnpm --filter @better-commerce/api staff:bootstrap-owner"
  },
  "devDependencies": {
    "turbo": "2.5.4"
  }
}
